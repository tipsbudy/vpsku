#!/usr/bin/env bash
#
# codespace-rdp — turn a GitHub Codespace into a temporary Linux desktop (VPS)
# reachable over Remote Desktop (RDP).
#
# Installs a lightweight XFCE desktop + xrdp inside the Codespace, then exposes
# the RDP port (3389) to the internet through ngrok or cloudflared so you can
# connect with the Windows "Remote Desktop Connection" client (mstsc).
#
# NOTE: A Codespace is already Linux — this only adds a GUI + RDP server.
#
# Usage (run INSIDE the Codespace):
#   chmod +x bin/codespace-rdp
#   bin/codespace-rdp                       # auto tunnel, generates a password
#   RDP_PASSWORD='secret' bin/codespace-rdp
#   TUNNEL=cloudflared bin/codespace-rdp
#   NGROK_AUTHTOKEN=xxxxx bin/codespace-rdp
#
# Env vars:
#   RDP_PORT         xrdp listen port              (default: 3389)
#   RDP_USER         desktop login user            (default: current user)
#   RDP_PASSWORD     login password                (default: random, printed)
#   DESKTOP          xfce | none (skip install)    (default: xfce)
#   TUNNEL           auto | ngrok | cloudflared    (default: auto)
#   NGROK_AUTHTOKEN  ngrok token (needed for ngrok TCP)

set -euo pipefail

RDP_PORT="${RDP_PORT:-3389}"
RDP_USER="${RDP_USER:-$(whoami)}"
DESKTOP="${DESKTOP:-xfce}"
TUNNEL="${TUNNEL:-auto}"

log()  { printf '\033[1;34m[*]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[+]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[!]\033[0m %s\n' "$*"; }
die()  { printf '\033[1;31m[x]\033[0m %s\n' "$*" >&2; exit 1; }

need_sudo() { if [ "$(id -u)" -eq 0 ]; then SUDO=""; else SUDO="sudo"; fi; }

# --------------------------------------------------------------------------
# 1. Install XFCE desktop + xrdp
# --------------------------------------------------------------------------
setup_desktop() {
  need_sudo
  log "Updating apt..."
  $SUDO apt-get update -qq

  if [ "$DESKTOP" = "xfce" ]; then
    if ! dpkg -l | grep -q xfce4-session; then
      log "Installing XFCE desktop (this can take a few minutes)..."
      $SUDO DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \
        xfce4 xfce4-goodies dbus-x11 x11-xserver-utils
    fi
  fi

  if ! command -v xrdp >/dev/null 2>&1; then
    log "Installing xrdp..."
    $SUDO DEBIAN_FRONTEND=noninteractive apt-get install -y -qq xrdp
  fi

  # Tell xrdp/Xorg sessions to launch XFCE for this user.
  local home; home="$(eval echo "~${RDP_USER}")"
  echo "startxfce4" | $SUDO tee "$home/.xsession" >/dev/null
  $SUDO chown "$RDP_USER" "$home/.xsession"

  # Set the login password.
  if [ -z "${RDP_PASSWORD:-}" ]; then
    RDP_PASSWORD="$(head -c 18 /dev/urandom | base64 | tr -d '/+=' | head -c 20)"
    GENERATED_PW=1
  fi
  echo "${RDP_USER}:${RDP_PASSWORD}" | $SUDO chpasswd

  # Configure xrdp port.
  $SUDO sed -i "s/^port=.*/port=${RDP_PORT}/" /etc/xrdp/xrdp.ini || true

  # xrdp's user needs access to the ssl cert key on some images.
  $SUDO adduser xrdp ssl-cert >/dev/null 2>&1 || true

  # No systemd in Codespaces — start the daemons directly.
  $SUDO pkill -x xrdp 2>/dev/null || true
  $SUDO pkill -x xrdp-sesman 2>/dev/null || true
  $SUDO /usr/sbin/xrdp-sesman
  $SUDO /usr/sbin/xrdp
  ok "xrdp listening on port ${RDP_PORT} (user ${RDP_USER})"
}

# --------------------------------------------------------------------------
# 2. Tunnels
# --------------------------------------------------------------------------
install_ngrok() {
  command -v ngrok >/dev/null 2>&1 && return 0
  log "Installing ngrok..."
  curl -sSL https://ngrok-agent.s3.amazonaws.com/ngrok.asc \
    | $SUDO tee /etc/apt/trusted.gpg.d/ngrok.asc >/dev/null
  echo "deb https://ngrok-agent.s3.amazonaws.com buster main" \
    | $SUDO tee /etc/apt/sources.list.d/ngrok.list >/dev/null
  $SUDO apt-get update -qq
  $SUDO apt-get install -y -qq ngrok
}

run_ngrok() {
  install_ngrok
  [ -n "${NGROK_AUTHTOKEN:-}" ] && ngrok config add-authtoken "$NGROK_AUTHTOKEN" >/dev/null
  print_banner "ngrok"
  warn "ngrok prints:  Forwarding tcp://0.tcp.ngrok.io:NNNNN -> localhost:${RDP_PORT}"
  warn "On Windows, open 'Remote Desktop Connection' and enter:"
  warn "    0.tcp.ngrok.io:NNNNN"
  echo
  exec ngrok tcp "${RDP_PORT}" --log stdout
}

install_cloudflared() {
  command -v cloudflared >/dev/null 2>&1 && return 0
  log "Installing cloudflared..."
  local arch; arch="$(dpkg --print-architecture)"
  curl -sSL -o /tmp/cloudflared.deb \
    "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${arch}.deb"
  $SUDO dpkg -i /tmp/cloudflared.deb >/dev/null 2>&1 || $SUDO apt-get install -y -qq -f
  rm -f /tmp/cloudflared.deb
}

run_cloudflared() {
  install_cloudflared
  print_banner "cloudflared"
  warn "cloudflared prints a https://<random>.trycloudflare.com hostname."
  warn "RDP over cloudflared needs a client-side proxy. On the CLIENT (Windows):"
  cat <<EOF

  1. Install cloudflared (winget install --id Cloudflare.cloudflared)
  2. Run:
       cloudflared access tcp --hostname <random>.trycloudflare.com --url localhost:${RDP_PORT}
  3. Open Remote Desktop Connection and connect to:
       localhost:${RDP_PORT}

EOF
  warn "TIP: ngrok is simpler for RDP — set NGROK_AUTHTOKEN to use it instead."
  echo
  exec cloudflared tunnel --url "tcp://localhost:${RDP_PORT}"
}

print_banner() {
  echo
  echo "=========================================================="
  echo "  Codespace Remote Desktop ready  (tunnel: $1)"
  echo "  user: ${RDP_USER}   rdp port: ${RDP_PORT}"
  if [ "${GENERATED_PW:-0}" = "1" ]; then
    echo "  password (generated): ${RDP_PASSWORD}"
  else
    echo "  password: (the one you supplied)"
  fi
  echo "=========================================================="
  echo
}

# --------------------------------------------------------------------------
# Main
# --------------------------------------------------------------------------
pick_tunnel() {
  case "$TUNNEL" in
    ngrok|cloudflared) echo "$TUNNEL" ;;
    auto)
      if [ -n "${NGROK_AUTHTOKEN:-}" ] || ngrok config check >/dev/null 2>&1; then
        echo "ngrok"; else echo "cloudflared"; fi ;;
    *) die "Unknown TUNNEL='$TUNNEL' (use auto|ngrok|cloudflared)" ;;
  esac
}

main() {
  log "Building temporary Linux desktop in this Codespace..."
  setup_desktop
  local chosen; chosen="$(pick_tunnel)"
  log "Tunnel provider: ${chosen}"
  case "$chosen" in
    ngrok)       run_ngrok ;;
    cloudflared) run_cloudflared ;;
  esac
}

main "$@"
