#!/usr/bin/env bash
#
# codespace-ssh — expose an SSH server from a GitHub Codespace via a tunnel.
#
# Runs an isolated sshd inside the Codespace (on its own port so it never
# clashes with the platform's built-in SSH) and publishes it to the internet
# through ngrok or cloudflared.
#
# Tunnel selection (TUNNEL=auto, the default):
#   - ngrok       if NGROK_AUTHTOKEN is set (or ngrok is already authed)
#   - cloudflared otherwise (free, no token, but client needs cloudflared)
#
# Usage:
#   bin/codespace-ssh                      # auto everything, prints a password
#   SSH_PASSWORD='secret' bin/codespace-ssh
#   SSH_PUBKEY="$(cat id_ed25519.pub)" bin/codespace-ssh
#   TUNNEL=cloudflared bin/codespace-ssh
#   NGROK_AUTHTOKEN=xxxxx TUNNEL=ngrok bin/codespace-ssh
#
# Env vars:
#   SSH_PORT         Port for the in-codespace sshd      (default: 2222)
#   SSH_USER         Login user                          (default: current user)
#   SSH_PASSWORD     Enable password auth with this value (default: random)
#   SSH_PUBKEY       Public key to add to authorized_keys (disables password)
#   TUNNEL           auto | ngrok | cloudflared          (default: auto)
#   NGROK_AUTHTOKEN  ngrok auth token (required for ngrok TCP tunnels)

set -euo pipefail

SSH_PORT="${SSH_PORT:-2222}"
SSH_USER="${SSH_USER:-$(whoami)}"
TUNNEL="${TUNNEL:-auto}"

log()  { printf '\033[1;34m[*]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[+]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[!]\033[0m %s\n' "$*"; }
die()  { printf '\033[1;31m[x]\033[0m %s\n' "$*" >&2; exit 1; }

need_sudo() {
  if [ "$(id -u)" -eq 0 ]; then SUDO=""; else SUDO="sudo"; fi
}

# --------------------------------------------------------------------------
# 1. Install + configure sshd
# --------------------------------------------------------------------------
setup_sshd() {
  need_sudo

  if ! command -v sshd >/dev/null 2>&1 && [ ! -x /usr/sbin/sshd ]; then
    log "Installing openssh-server..."
    $SUDO apt-get update -qq
    $SUDO DEBIAN_FRONTEND=noninteractive apt-get install -y -qq openssh-server
  fi

  $SUDO mkdir -p /run/sshd /var/run/sshd

  # Generate host keys if missing.
  $SUDO ssh-keygen -A >/dev/null 2>&1 || true

  local cfg=/etc/ssh/sshd_config.d/codespace-ssh.conf
  log "Writing sshd config -> $cfg"
  $SUDO mkdir -p /etc/ssh/sshd_config.d

  if [ -n "${SSH_PUBKEY:-}" ]; then
    # Key-based auth: harden by disabling passwords.
    local home; home="$(eval echo "~${SSH_USER}")"
    $SUDO mkdir -p "$home/.ssh"
    echo "$SSH_PUBKEY" | $SUDO tee -a "$home/.ssh/authorized_keys" >/dev/null
    $SUDO chmod 700 "$home/.ssh"
    $SUDO chmod 600 "$home/.ssh/authorized_keys"
    $SUDO chown -R "$SSH_USER" "$home/.ssh"
    AUTH_MODE="publickey"
    $SUDO tee "$cfg" >/dev/null <<EOF
Port ${SSH_PORT}
PasswordAuthentication no
PubkeyAuthentication yes
PermitRootLogin no
AllowUsers ${SSH_USER}
EOF
  else
    # Password auth: use provided password or generate one.
    if [ -z "${SSH_PASSWORD:-}" ]; then
      SSH_PASSWORD="$(head -c 18 /dev/urandom | base64 | tr -d '/+=' | head -c 20)"
      GENERATED_PW=1
    fi
    echo "${SSH_USER}:${SSH_PASSWORD}" | $SUDO chpasswd
    AUTH_MODE="password"
    $SUDO tee "$cfg" >/dev/null <<EOF
Port ${SSH_PORT}
PasswordAuthentication yes
PubkeyAuthentication yes
PermitRootLogin no
AllowUsers ${SSH_USER}
EOF
  fi

  # (Re)start sshd on our port. Codespaces has no systemd, so run directly.
  $SUDO pkill -f "sshd.*${SSH_PORT}" 2>/dev/null || true
  $SUDO /usr/sbin/sshd -f "$cfg"
  ok "sshd listening on port ${SSH_PORT} (${AUTH_MODE} auth, user ${SSH_USER})"
}

# --------------------------------------------------------------------------
# 2. Tunnel: ngrok
# --------------------------------------------------------------------------
install_ngrok() {
  command -v ngrok >/dev/null 2>&1 && return 0
  log "Installing ngrok..."
  curl -sSL https://ngrok-agent.s3.amazonaws.com/ngrok.asc \
    | $SUDO tee /etc/apt/trusted.gpg.d/ngrok.asc >/dev/null
  echo "deb https://ngrok-agent.s3.amazonaws.com buster main" \
    | $SUDO tee /etc/apt/sources.list.d/ngrok.list >/dev/null
  $SUDO apt-get update -qq
  $SUDO apt-get install -y -qq ngrok
}

run_ngrok() {
  install_ngrok
  if [ -n "${NGROK_AUTHTOKEN:-}" ]; then
    ngrok config add-authtoken "$NGROK_AUTHTOKEN" >/dev/null
  fi
  ok "Starting ngrok TCP tunnel -> port ${SSH_PORT}"
  print_connect_banner "ngrok"
  echo
  warn "When the tunnel comes up, ngrok prints a line like:"
  warn "  Forwarding  tcp://0.tcp.ngrok.io:12345 -> localhost:${SSH_PORT}"
  warn "Connect with:  ssh ${SSH_USER}@0.tcp.ngrok.io -p 12345"
  echo
  exec ngrok tcp "${SSH_PORT}" --log stdout
}

# --------------------------------------------------------------------------
# 3. Tunnel: cloudflared
# --------------------------------------------------------------------------
install_cloudflared() {
  command -v cloudflared >/dev/null 2>&1 && return 0
  log "Installing cloudflared..."
  local arch; arch="$(dpkg --print-architecture)"
  curl -sSL -o /tmp/cloudflared.deb \
    "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${arch}.deb"
  $SUDO dpkg -i /tmp/cloudflared.deb >/dev/null 2>&1 \
    || $SUDO apt-get install -y -qq -f
  rm -f /tmp/cloudflared.deb
}

run_cloudflared() {
  install_cloudflared
  ok "Starting cloudflared tunnel -> tcp://localhost:${SSH_PORT}"
  print_connect_banner "cloudflared"
  echo
  warn "cloudflared will print a https://<random>.trycloudflare.com hostname."
  warn "On the CLIENT machine, install cloudflared and add to ~/.ssh/config:"
  cat <<EOF

  Host my-codespace
    HostName <random>.trycloudflare.com
    User ${SSH_USER}
    Port ${SSH_PORT}
    ProxyCommand cloudflared access ssh --hostname %h

  Then:  ssh my-codespace
EOF
  echo
  exec cloudflared tunnel --url "tcp://localhost:${SSH_PORT}"
}

# --------------------------------------------------------------------------
# Shared output
# --------------------------------------------------------------------------
print_connect_banner() {
  local provider="$1"
  echo
  echo "=========================================================="
  echo "  Codespace SSH ready  (tunnel: ${provider})"
  echo "  user: ${SSH_USER}   port (internal): ${SSH_PORT}"
  if [ "${AUTH_MODE:-}" = "password" ]; then
    if [ "${GENERATED_PW:-0}" = "1" ]; then
      echo "  password (generated): ${SSH_PASSWORD}"
    else
      echo "  password: (the one you supplied)"
    fi
  else
    echo "  auth: public key"
  fi
  echo "=========================================================="
}

# --------------------------------------------------------------------------
# Main
# --------------------------------------------------------------------------
pick_tunnel() {
  case "$TUNNEL" in
    ngrok|cloudflared) echo "$TUNNEL" ;;
    auto)
      if [ -n "${NGROK_AUTHTOKEN:-}" ] || ngrok config check >/dev/null 2>&1; then
        echo "ngrok"
      else
        echo "cloudflared"
      fi
      ;;
    *) die "Unknown TUNNEL='$TUNNEL' (use auto|ngrok|cloudflared)" ;;
  esac
}

main() {
  log "Setting up SSH access for this Codespace..."
  setup_sshd
  local chosen; chosen="$(pick_tunnel)"
  log "Tunnel provider: ${chosen}"
  case "$chosen" in
    ngrok)       run_ngrok ;;
    cloudflared) run_cloudflared ;;
  esac
}

main "$@"
