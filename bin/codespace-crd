#!/usr/bin/env bash
#
# codespace-crd — turn a GitHub Codespace into a Linux desktop reachable through
# Chrome Remote Desktop (https://remotedesktop.google.com).
#
# Unlike RDP/SSH-over-tunnel, Chrome Remote Desktop needs NO ngrok/cloudflared
# and NO open port: the host connects OUTBOUND to Google, and you access the
# desktop from your browser. This script installs XFCE + the CRD host and
# prepares the session; you then paste the one-time authorization command that
# Google gives you at https://remotedesktop.google.com/headless
#
# Usage (run INSIDE the Codespace):
#   chmod +x bin/codespace-crd
#   bin/codespace-crd
#
# Then follow the printed steps to authorize and set a 6-digit PIN.

set -euo pipefail

CRD_USER="${CRD_USER:-$(whoami)}"

log()  { printf '\033[1;34m[*]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[+]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[!]\033[0m %s\n' "$*"; }

need_sudo() { if [ "$(id -u)" -eq 0 ]; then SUDO=""; else SUDO="sudo"; fi; }

main() {
  need_sudo
  log "Updating apt..."
  $SUDO apt-get update -qq

  # 1. Desktop environment (XFCE — lightweight and CRD-friendly).
  if ! dpkg -l | grep -q xfce4-session; then
    log "Installing XFCE desktop (a few minutes the first time)..."
    $SUDO DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \
      xfce4 xfce4-goodies dbus-x11 xscreensaver
  fi

  # 2. Chrome Remote Desktop host.
  if ! command -v /opt/google/chrome-remote-desktop/start-host >/dev/null 2>&1; then
    log "Installing Chrome Remote Desktop..."
    local arch; arch="$(dpkg --print-architecture)"
    curl -sSL -o /tmp/crd.deb \
      "https://dl.google.com/linux/direct/chrome-remote-desktop_current_${arch}.deb"
    $SUDO DEBIAN_FRONTEND=noninteractive apt-get install -y -qq /tmp/crd.deb \
      || $SUDO apt-get install -y -qq -f
    rm -f /tmp/crd.deb
  fi

  # 3. Tell CRD which desktop session to launch.
  log "Configuring CRD to start XFCE..."
  echo "exec /etc/X11/Xsession /usr/bin/xfce4-session" \
    | $SUDO tee /etc/chrome-remote-desktop-session >/dev/null

  # Disable Xorg's "first session" wizard noise.
  $SUDO bash -c 'echo "[Desktop Entry]" > /usr/share/xsessions/xfce.desktop' 2>/dev/null || true

  # 4. Make sure the user can run CRD.
  $SUDO usermod -a -G chrome-remote-desktop "$CRD_USER" 2>/dev/null || true

  ok "XFCE + Chrome Remote Desktop installed."
  cat <<EOF

==========================================================
  NEXT STEPS — authorize this machine with Google
==========================================================

  1. On your PC, open:
        https://remotedesktop.google.com/headless

  2. Click "Begin" -> "Next" -> "Authorize".
     Sign in with the SAME Google account you'll use to connect.

  3. Google shows a "Debian Linux" command that looks like:

        DISPLAY= /opt/google/chrome-remote-desktop/start-host \\
          --code="4/xxxxxxxx" \\
          --redirect-url="https://remotedesktop.google.com/_/oauthredirect" \\
          --name=\$(hostname)

  4. COPY that whole command and PASTE it into THIS terminal, then Enter.

  5. It will ask you to set a 6-digit PIN (twice). Remember it.

  6. Open https://remotedesktop.google.com/access on any device,
     pick this machine, enter the PIN -> your Linux desktop appears.

  NOTE: keep the Codespace running. If it stops, re-run this script
  is NOT needed — just the start-host command again if auth was lost.
==========================================================
EOF
}

main "$@"
